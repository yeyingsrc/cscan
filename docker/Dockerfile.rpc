# CSCAN RPC 服务 Dockerfile
# 支持多架构: linux/amd64, linux/arm64

FROM golang:1.25.7-alpine AS builder

WORKDIR /app

# 安装编译依赖
RUN apk add --no-cache git curl

# 复制 go.mod 和 go.sum
COPY go.mod go.sum ./
ENV GOTOOLCHAIN=auto
RUN go mod download

# 复制源代码
COPY . .

# 下载 ip2region 数据库（编译时准备）
RUN mkdir -p /app/data && \
    curl -sL "https://github.com/lionsoul2014/ip2region/raw/master/data/ip2region_v4.xdb" -o /app/data/ip2region_v4.xdb && \
    curl -sL "https://github.com/lionsoul2014/ip2region/raw/master/data/ip2region_v6.xdb" -o /app/data/ip2region_v6.xdb && \
    echo "ip2region databases downloaded"

# 编译 RPC 服务
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /cscan-rpc ./rpc/task/task.go

# 运行镜像
FROM alpine:3.19

WORKDIR /app

# 安装运行时依赖（libpcap 是 gopacket 的运行时依赖）
RUN apk add --no-cache ca-certificates tzdata

# 设置时区
ENV TZ=Asia/Shanghai

# 复制编译产物
COPY --from=builder /cscan-rpc .
COPY --from=builder /app/data ./data/
COPY docker/task.yaml ./etc/

EXPOSE 9000

CMD ["./cscan-rpc", "-f", "etc/task.yaml"]
